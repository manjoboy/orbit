{
  "name": "chiefofstaff",
  "version": "0.1.0",
  "private": true,
  "description": "Stateful, compounding intelligence platform — your personal Chief of Staff",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed/index.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "worker:dev": "tsx --watch src/workers/index.ts",
    "worker:start": "tsx src/workers/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "next": "^16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@prisma/client": "^6.19.0",
    "@anthropic-ai/sdk": "^0.80.0",

    "@supabase/supabase-js": "^2.99.0",
    "@supabase/ssr": "^0.9.0",

    "bullmq": "^5.30.0",
    "ioredis": "^5.6.0",

    "openai": "^4.80.0",

    "@slack/web-api": "^7.14.0",
    "@slack/bolt": "^4.6.0",
    "googleapis": "^144.0.0",
    "@octokit/rest": "^21.1.0",
    "@notionhq/client": "^3.1.0",
    "@linear/sdk": "^30.0.0",

    "zod": "^3.24.0",
    "date-fns": "^4.1.0",
    "uuid": "^11.1.0",
    "lodash-es": "^4.17.21",
    "p-limit": "^6.2.0",
    "p-retry": "^6.2.0",

    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.0",
    "lucide-react": "^0.475.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "sonner": "^2.0.0",
    "recharts": "^2.15.0",
    "framer-motion": "^12.0.0",

    "structlog": "^0.1.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "prisma": "^6.19.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/lodash-es": "^4.17.12",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "@playwright/test": "^1.50.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.0",
    "@eslint/eslintrc": "^3.3.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
